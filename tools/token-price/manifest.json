{
  "name": "token-price",
  "description": "Fetches Solana token prices and market data. Supports price lookup for known tokens (SOL, USDC, JUP, etc.) via Jupiter, plus market discovery, trend analysis, and unknown token search via DexScreener.",
  "version": "0.2.0",
  "executable": "./bin/token-price",
  "required_capabilities": ["network-manager"],
  "env": [
    { "name": "JUPITER_API_KEY",        "sensitive": true,  "required": false },
    { "name": "JUPITER_RATE_LIMIT_RPS", "sensitive": false, "required": false }
  ],
  "timeout": "90s",
  "llm_options": {
    "primary": "gemini-2.5-pro",
    "supported": [
      { "model": "gemini-2.5-flash",         "provider": "google"    },
      { "model": "gpt-4o-mini",              "provider": "openai"    },
      { "model": "claude-haiku-4-5-20251001","provider": "anthropic" }
    ]
  }
}
